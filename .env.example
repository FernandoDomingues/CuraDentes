# Modelo das variáveis de ambiente. Copie para .env.local e preencha.
#   cp .env.example .env.local
#
# Onde achar: Supabase → Project Settings → API (URL e anon key).
# A anon key é pública (vai pro navegador). NUNCA coloque a service_role key aqui.

NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key-aqui
NEXT_PUBLIC_GOOGLE_CLIENT_ID=seu-google-client-id.apps.googleusercontent.com
