<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Não redireciona arquivos e pastas que existem de verdade (JS, CSS, imagens etc.)
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d

  # Redireciona tudo para index.html — React Router cuida do resto
  RewriteRule ^ index.html [L]
</IfModule>
